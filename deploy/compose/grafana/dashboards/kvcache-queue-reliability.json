        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "kvcache_queue_metrics_up or vector(0)",
          "instant": true,
          "range": false
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
