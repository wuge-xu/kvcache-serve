        "h": 9
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(kvcache_queue_jobs_submitted_total[5m]))",
          "legendFormat": "Submitted / sec",
          "range": true
        },
        {
          "refId": "B",
