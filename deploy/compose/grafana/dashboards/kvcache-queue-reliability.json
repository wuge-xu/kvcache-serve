    {
      "id": 15,
      "type": "timeseries",
      "title": "Queue Wait Latency",
      "description": "任务入队到 Worker 开始处理的 P50/P95 等待时间。",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "gridPos": {
        "x": 0,
        "y": 17,
        "w": 12,
        "h": 9
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(kvcache_worker_job_wait_seconds_bucket[5m])))",
          "legendFormat": "P50",
          "range": true
        },
